{
  "provider_id": {
    "description": "使用的LLM提供商",
    "type": "string",
    "hint": "选择用于分析脏话的LLM模型",
    "_special": "select_provider"
  },
  "enable_groups": {
    "description": "启用监控的群聊ID列表",
    "type": "list",
    "default": [],
    "hint": "留空表示监控所有群聊，填写群聊ID则只监控指定群聊"
  },
  "ignore_groups": {
    "description": "忽略监控的群聊ID列表",
    "type": "list",
    "default": [],
    "hint": "填写的群聊ID将不会被监控"
  },
  "enable_http_api": {
    "description": "是否启用HTTP API",
    "type": "bool",
    "default": false,
    "hint": "启用后将启动HTTP服务器，提供数据查询API"
  },
  "http_host": {
    "description": "HTTP服务器绑定地址",
    "type": "string",
    "default": "0.0.0.0"
  },
  "http_port": {
    "description": "HTTP服务器端口",
    "type": "int",
    "default": 10050
  },
  "admin_password": {
    "description": "管理密码",
    "type": "string",
    "default": "m1234",
    "hint": "用于Web界面清空数据的验证密码"
  }
}
